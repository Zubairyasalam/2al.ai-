generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String    @default("CUSTOMER") // SUPER_ADMIN, ADMIN, CUSTOMER
  plan          String    @default("NONE")
  paymentStatus String    @default("UNPAID")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  projects      Project[]
  domains       Domain[]
  apiKeys       ApiKey[]
  widgetConfigs WidgetConfig[]
  usageLogs     UsageLog[]
  auditLogs     AuditLog[]
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Project {
  id        String   @id @default(cuid())
  userId    String
  url       String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  scans     Scan[]
}

model Scan {
  id          String   @id @default(cuid())
  projectId   String
  status      String   @default("PENDING") // PENDING, COMPLETED, FAILED
  score       Int?
  issuesCount Int      @default(0)
  createdAt   DateTime @default(now())
  completedAt DateTime?

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  issues      Issue[]
}

model Issue {
  id          String   @id @default(cuid())
  scanId      String
  type        String   // IMAGE, BUTTON, HEADING, COLOR, HTML, etc.
  severity    String   // CRITICAL, HIGH, MEDIUM, LOW
  element     String   // The HTML snippet
  description String   // Issue description
  suggestion  String?  // AI generated fix

  scan        Scan     @relation(fields: [scanId], references: [id], onDelete: Cascade)
}

model Domain {
  id                 String    @id @default(cuid())
  userId             String
  websiteName        String?
  domain             String    @unique
  canonicalDomain    String?
  environment        String    @default("PRODUCTION") // PRODUCTION, STAGING, DEVELOPMENT
  status             String    @default("PENDING_VERIFICATION") // PENDING_VERIFICATION, ACTIVE, SUSPENDED
  verified           Boolean   @default(false)
  verificationMethod String    @default("META") // META, DNS, HTML
  verificationToken  String    @unique
  verifiedAt         DateTime?
  notes              String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  apiKeys            ApiKey[]
}

model ApiKey {
  id         String   @id @default(cuid())
  userId     String
  name       String
  key        String   @unique
  status     String   @default("ACTIVE") // ACTIVE, REVOKED, EXPIRED
  domainId   String?
  domainName String?
  lastUsedAt DateTime?
  createdAt  DateTime @default(now())
  expiresAt  DateTime?

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  domain     Domain?  @relation(fields: [domainId], references: [id], onDelete: SetNull)
}

model WidgetConfig {
  id              String   @id @default(cuid())
  userId          String   @unique
  draftConfig     String   @default("{}") // JSON string
  publishedConfig String   @default("{}") // JSON string
  lastPublishedAt DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UsageLog {
  id          String   @id @default(cuid())
  userId      String
  domain      String
  month       String   // e.g. "2026-07"
  pageViews   Int      @default(0)
  widgetLoads Int      @default(0)
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, domain, month])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String   // e.g. "CREATED_API_KEY", "VERIFIED_DOMAIN", "PUBLISHED_WIDGET"
  details   String   // JSON or text description
  ipAddress String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
